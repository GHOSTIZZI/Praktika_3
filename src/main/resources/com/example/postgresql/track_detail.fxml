<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<VBox spacing="5" style="-fx-padding: 20;-fx-padding: 20; -fx-background-color: #0f0f0f;" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.postgresql.TrackDetailController"
      stylesheets="@style.css">

    <HBox alignment="CENTER_LEFT" >
        <Button onAction="#goBack" style="     -fx-font-size: 25px;     -fx-padding: 9 16 9 16;     -fx-text-fill: #ffffff;     -fx-border-color: #ccc;     -fx-border-width: 1px;     -fx-background-radius: 50%;     -fx-border-radius: 50%;     -fx-cursor: hand;     -fx-background-color: #0f0f0f; " text="←" />

    </HBox>
    <HBox alignment="CENTER" >
        <Label style="-fx-font-size: 18px; -fx-text-fill: #b3b3b3;" text="🔊" />
        <Slider fx:id="volumeSlider" styleClass="volume-slider" max="1.0" min="0" prefWidth="250" value="0.5" />
    </HBox>

    <VBox alignment="CENTER" spacing = "10" >
        <ImageView fx:id="coverImage" fitHeight="530" fitWidth="530" />
        <Label fx:id="titleLabel" style="-fx-font-size: 22px; -fx-font-weight: bold;  -fx-text-fill: #ffffff"  />
        <Label fx:id="artistLabel" style="-fx-font-size: 18px;" />


        <HBox alignment="CENTER"  >
            <Button fx:id="favoriteButton" onAction="#addToFavorites"  />
        </HBox>



        <HBox alignment="CENTER">
            <Label fx:id="currentTimeLabel" style="-fx-font-size: 14px; -fx-text-fill: white;" text="0:00" />
            <Slider fx:id="progressSlider" styleClass="progress-slider" prefWidth="400" />
            <Label fx:id="durationLabel" style="-fx-font-size: 14px; -fx-text-fill: white;" text="0:00" />
        </HBox>


        <HBox alignment="CENTER">
            <Button fx:id="libraryadd"   onAction="#addToPlaylist"  style="-fx-background-color: transparent; -fx-font-size: 17px;" />
            <Button fx:id="prevButton"  onAction="#handlePrevButton" style="-fx-background-color: #0f0f0f; -fx-text-fill: white; -fx-font-size: 15px; "/>
            <Button fx:id="playPauseButton"  onAction="#togglePlayPause" style="-fx-background-color: #0f0f0f; -fx-text-fill: white; -fx-font-size: 25px;"/>
            <Button fx:id="nextButton"  onAction="#handleNextButton" style=" -fx-background-color: #0f0f0f; -fx-text-fill: white; -fx-font-size: 15px;"/>
            <Button fx:id="loopButton"
                    onAction="#toggleLoop"
                    style="-fx-background-color: transparent;">
                <HBox.margin>
                    <Insets left="15"/>
                </HBox.margin>
            </Button>
        </HBox>

    </VBox>

</VBox>
